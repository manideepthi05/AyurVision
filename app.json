{
  "expo": {
    "name": "AyurVision",
    "slug": "Planty",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "planty",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSCameraUsageDescription": "AyurVision needs camera access to identify plants"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#052e16",
        "foregroundImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.sern_gate.Planty",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "llama.rn",
      "./plugins/withPlantAssets",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#052e16",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d40ba28e-bf07-44bf-84c5-ba203bcea9c5"
      }
    }
  }
}